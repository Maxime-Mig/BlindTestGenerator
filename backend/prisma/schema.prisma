generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Song {
  id        Int      @id @default(autoincrement())
  title     String
  artist    String
  genre     String?
  filePath  String   @unique
  duration  Float?
  createdAt DateTime @default(now())
}
