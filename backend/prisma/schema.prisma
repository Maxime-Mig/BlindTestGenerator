generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Song {
  id          Int      @id @default(autoincrement())
  title       String
  artist      String
  filePath    String   @unique
  sourceType  String?  // Anime, Game, Movie, Series
  difficulty  String?  // Easy, Normal, Hard
  createdAt   DateTime @default(now())
}
